<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext (HTTP) traffic globally.
         Users connect to self-hosted media servers (Emby, Jellyfin, Plex,
         Audiobookshelf) on local networks that typically use HTTP.
         Domain-based rules don't work for raw IP addresses. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
